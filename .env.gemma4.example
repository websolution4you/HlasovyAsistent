# ============================================
# GEMMA 4 VOICE ASSISTANT - ENVIRONMENT CONFIG
# ============================================

# --- Gemma 4 Model Configuration ---
# Cesta k lokálnemu Gemma 4 modelu
# Možnosti: gemma-4-e4b (4B parametrov) alebo gemma-4-e2b (2B parametrov)
GEMMA4_MODEL_PATH=./models/gemma-4-e4b

# Použiť vLLM (true) alebo google-ai-edge SDK (false)
USE_VLLM=true

# GPU memory utilization (0.0 - 1.0)
# Nižšia hodnota = menej VRAM, ale pomalšie
# Vyššia hodnota = viac VRAM, ale rýchlejšie
GPU_MEMORY_UTILIZATION=0.9

# --- Server Configuration ---
PORT=8000

# CORS origins (čiarkou oddelené alebo *)
CORS_ALLOW_ORIGINS=*

# --- Supabase Database ---
# Pre ukladanie objednávok a menu
CORE_SUPABASE_URL=your_supabase_project_url
CORE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
TENANT_ID=your_tenant_id

# --- Twilio (voliteľné) ---
# Pre produkčné nasadenie s Twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

# --- Advanced Settings (voliteľné) ---
# Maximálna dĺžka kontextu
# MAX_MODEL_LEN=8192

# Temperature pre generovanie (0.0 - 2.0)
# TEMPERATURE=0.7

# Top-p sampling
# TOP_P=0.9

# VAD threshold pre detekciu reči (0.0 - 1.0)
# VAD_THRESHOLD=0.02

# Silence duration pre ukončenie reči (sekundy)
# SILENCE_DURATION=0.8
